# Copy to .env.local for local development, or set in the Vercel project settings.

# Base URL of the FastAPI backend (no trailing slash).
# Local development: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Supabase (persistence layer — V4) ────────────────────────────────────────
# Leave BLANK to run the app in stateless mode (public AI pages keep working;
# auth/campaign routes stay disabled). Fill in to enable sign in + campaigns.
# Project URL, e.g. https://abcdefgh.supabase.co  (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key — safe to expose to the browser; RLS enforced server-side.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
