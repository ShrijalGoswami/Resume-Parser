# Copy to .env.local (or .env) and fill in real values.
# On Railway/Render, set these as environment variables instead.

# Deployment environment: development | staging | production
ENVIRONMENT=development

# Groq API key (required for LLM analysis endpoints). Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Ephemeral per-request upload directory used by /ats-analysis and /match-analysis.
# Leave unset to use the OS temp dir (works on serverless /tmp, Railway, Render).
# TEMP_UPLOAD_DIR=/tmp/hirelens_uploads

# Maximum upload size in megabytes.
MAX_FILE_SIZE_MB=10

# Allowed resume file extensions (JSON list).
ALLOWED_EXTENSIONS=[".pdf", ".docx"]

# Comma-separated list of allowed CORS origins, e.g.
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
# "*" allows any origin (credentials disabled in that case).
ALLOWED_ORIGINS=*

# ── Supabase (persistence layer — V4) ────────────────────────────────────────
# Leave BLANK to run the app fully stateless (existing AI endpoints unaffected).
# Fill in to enable auth, campaigns, and persistence.
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Public anon key (safe for clients; RLS enforced). Settings → API.
SUPABASE_ANON_KEY=
# Service role key — TRUSTED backend only, bypasses RLS. NEVER expose to clients.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret used to verify user access tokens (Settings → API → JWT Secret).
SUPABASE_JWT_SECRET=
# Signed URL lifetime for private file downloads (seconds).
SIGNED_URL_TTL_SECONDS=3600
